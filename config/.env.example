# Copy this file to .env and fill in your values

# API Keys for data sources
HKEX_API_KEY=
BLOOMBERG_API_KEY=
YAHOO_FINANCE_API_KEY=

# Email notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Slack notifications
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#hkex-alerts

# Custom webhook
WEBHOOK_URL=
WEBHOOK_SECRET=

# Database (optional - defaults to SQLite)
DATABASE_URL=

# Security
API_SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here

# Development
DEBUG=false
LOG_LEVEL=INFO
